	"scroll-step": 5.0,
	"on-scroll-up": "$HOME/.local/share/archriot/install/archriot --volume inc",
	"on-scroll-down": "$HOME/.local/share/archriot/install/archriot --volume dec",
	"smooth-scrolling-threshold": 1,
	"tooltip": true,
	"tooltip-format": "{status_icon} {dynamic}\nLeft Click: previous\nMid Click: Pause\nRight Click: Next",
	"player-icons": {
		"chromium": "ÓĚÉ",
		"chrome": "ÔČ®",
		"brave": "ÓĽ≠",
		"default": "ÔÄĀ",
		"firefox": "ÓĚÖ",
		"kdeconnect": "ÔĆ≤",
		"mopidy": "",
		"mpv": "ůįźĻ",
		"spotify": "ÔÜľ",
		"vlc": "ůįēľ",
		"lollypop": "Óä£",
	},
	"status-icons": {
		"paused": "ůįźé",
		"playing": "",
		"stopped": "",
	},
	// "ignored-players": ["firefox"]
	"max-length": 40,
},


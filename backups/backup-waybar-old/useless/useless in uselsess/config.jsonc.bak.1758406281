{
  "layer": "top",
  "position": "top",
  "margin-top": 13,
  "modules-left": ["clock", "custom/notification", "custom/github", "hyprland/window"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [ "custom/pacman", "pulseaudio", "battery", "network"],
  "height": 40,


  "custom/github": {
    "exec": "/home/adnanmalik/.local/bin/githubContributions.sh",
    "interval": 300,
    "return-type": "json",
    "format": "{text}", 
    "tooltip": true,
    "on-click": "xdg-open https://github.com/Adnan-Malik-26"
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "ο²Δ<span foreground='red'><sup>οë³</sup></span>",
      "none": "ο²Δ",
      "dnd-notification": "ο΅Ζ<span foreground='red'><sup>οë³</sup></span>",
      "dnd-none": "ο΅Ζ",
      "inhibited-notification": "ο²Δ<span foreground='red'><sup>οë³</sup></span>",
      "inhibited-none": "ο²Δ",
      "dnd-inhibited-notification": "ο΅Ζ<span foreground='red'><sup>οë³</sup></span>",
      "dnd-inhibited-none": "ο΅Ζ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "custom/launcher": {
    "format": "ο¨É",
    "tooltip-format": "Launch your favorite apps"
  },

  "custom/pacman": {
    "format": "οÜ΅  {}",
    "interval": "once",
    "exec": "checkupdates | wc -l",
    "on-click": "update-system",
    "signal": 8,
    "tooltip-format": "{} updates available"
  },

  "custom/media": {
    "format": "{}",
    "escape": true,
    "return-type": "json",
    "max-length": 40,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl stop",
    "smooth-scrolling-threshold": 1, // This value was tested using a trackpad, it should be lowered if using a mouse.
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null" // Script in resources/custom_modules folder
  },

  "battery": {
    "format": "{icon}  {capacity}%",
    "format-charging": "σΑ²³  {capacity}%",
    "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
    "tooltip-format": "Battery is at {capacity}%" 
  },

  "clock": {
    "format": "σΑΞî  {:%I:%M %p}",
    "format-alt": "σΑΞî  {:%a, %d. %b  %I:%M %p}",
    "tooltip-format": "Date: {:%Y-%m-%d}"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "σΑ²± {volume}%",
    "format-muted": "σΑ•¹",
    "scroll-step": 1,
    "on-click": "pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"],
    "format-icons": {
      "headphone": "οÄΞ",
      "hands-free": "ο•ê",
      "headset": "σΑ΄é",
      "phone": "ο²ï",
      "portable": "ο²ï",
      "car": "οÜΙ",
      "default": ["σΑ•Ä", "σΑïΨ"]
    },
    "tooltip-format": "Volume: {volume}%"
  },

  "network": {
    "interface": "wlan0",
    "format": "{ifname}",
    "format-wifi": "{icon} {essid}",
    "format-ethernet": "σΑàÄ {ipaddr}/{cidr}",
    "format-disconnected": "σΑΛ≠ Disconnected",
    "max-length": 50,
    "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
    "tooltip-format": "Connected to {essid}"
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "δΗÄ",
      "2": "δΚ¨",
      "3": "δΗâ",
      "4": "ε¦¦",
      "5": "δΚî",
      "6": "εÖ≠",
      "7": "δΗÉ",
      "8": "εÖΪ",
      "9": "δΙù",
      "10": "εç¹"
    },
    "persistent-workspaces": {
      "*": 5 // 5 workspaces by default on every monitor
    },
    "sort-by-number": true
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}   {percent}%",
    "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"]
  },

  "custom/weather": {
    "exec": "${HOME}/.config/waybar/scripts/get_weather.sh Bangalore+India",
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "interval": 3600
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power mode: {profile}",
    "tooltip": true,
    "format-icons": {
      "default": "οÉß",
      "performance": "σΑ††",
      "balanced": "σΑöÄ",
      "power-saver": "σΑ¨Σ"
    }
  },

  "hyprland/window": {
    "format": "{class}",
    "separate-outputs": true,
    "icon": false,
    "icon-size": 18,
    "rewrite": {
      "Mozilla Firefox": "Firefox",
      "firefox": "Firefox",
      "(.*) Thunar": "Thunar",
      "(.*)obs(.*)": "OBS",
      "Spotify (.*)": "Spotify",
      "discord(.*)": "Discord",
      "Code": "VS Code",
      "Docker Desktop": " Docker",
      "kitty": "Kitty",
      "zen": "Zen",
      "com.mitchellh.ghostty": "Ghostty",
      "org.telegram.desktop": "Telegram",
      "(.*)whatsapp(.*)": "Whatsapp"
    } 
},
  
  "cpu": {
    "interval": 10,
    "format": "ο£Φ    {}%",
    "max-length": 10
  },

  "memory": {
    "interval": 30,
    "format": "νΩÖ    {}%",
    "max-length": 10
  },

  "disk": {
    "interval": 30,
    "format": "οÉ΅   {percentage_used}% used on {path}",
    "path": "/"
  }
}
